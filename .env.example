# Instagram credentials
IG_USERNAME=your_username
IG_PASSWORD=your_password

# Comma-separated Instagram DM thread URLs to watch
# Example: https://www.instagram.com/direct/t/1234567890/
INSTAGRAM_WATCHED_THREADS=

# Browser/webdriver settings
FIREFOX_PROFILE_DIR=/absolute/path/to/dedicated/firefox-profile
# Optional override. Leave empty to use Selenium Manager / PATH resolution.
GECKODRIVER_PATH=
HEADLESS=false
PAGE_LOAD_TIMEOUT_SEC=30

# Polling and mode timing
IDLE_MIN_SEC=120
IDLE_MAX_SEC=240
ACTIVE_MIN_SEC=10
ACTIVE_MAX_SEC=20
FIRST_REPLY_MIN_SEC=45
FIRST_REPLY_MAX_SEC=150
FOLLOWUP_REPLY_MIN_SEC=8
FOLLOWUP_REPLY_MAX_SEC=45
CONVERSATION_EXPIRE_MIN_SEC=480
CONVERSATION_EXPIRE_MAX_SEC=720

# Browser recycle safety
IDLE_BROWSER_GRACE_SEC=900
FORCE_BROWSER_RESTART_SEC=14400

# Reply behavior
ENABLE_SENDING=false
SKIP_REPLY_PROBABILITY=0.20
DRY_RUN_REPLY_TEXT=Thanks! I saw your message.

# LLM responder (OpenAI-compatible)
# Keep secrets in .env (this file is a template).
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_HISTORY_N=20
LLM_MASTER_PROMPT_FILE=./master_prompt.txt
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=200
LLM_TIMEOUT_SEC=30

# Message history storage bound (per thread)
MAX_STORED_MESSAGES_PER_THREAD=1000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log
